# ============================================================
# InterviewForge AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── Application ─────────────────────────────────────────────
NODE_ENV=development
APP_NAME=InterviewForge AI
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PREFIX=/api/v1
PORT=4000

# ── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_USER=interviewforge
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=interviewforge_db
DATABASE_URL=postgresql://interviewforge:your_postgres_password_here@localhost:5432/interviewforge_db?schema=public

# ── Cache & Queue (Redis) ────────────────────────────────────
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@localhost:6379

# ── JWT Authentication ───────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars_here
JWT_REFRESH_EXPIRES_IN=7d
JWT_EMAIL_SECRET=your_email_verification_secret_here
JWT_RESET_SECRET=your_password_reset_secret_here

# ── OAuth Providers ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/oauth/google/callback

GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/oauth/github/callback

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=noreply@interviewforge.ai
EMAIL_FROM_NAME=InterviewForge AI

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# ── Cloudinary (File Storage) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_PRESET=interviewforge_uploads

# ── Stripe Payments ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_MONTHLY_PRICE_ID=price_your_monthly_price_id_here
STRIPE_YEARLY_PRICE_ID=price_your_yearly_price_id_here

# ── Judge0 API (Code Execution) ──────────────────────────────
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your_judge0_api_key_here
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# ── Frontend (Next.js Public Variables) ─────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
NEXT_PUBLIC_APP_NAME=InterviewForge AI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Security ─────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3000

# ── Cookie Settings ──────────────────────────────────────────
COOKIE_SECRET=your_cookie_secret_here
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=logs

# ── pgAdmin (Dev Tool) ───────────────────────────────────────
PGADMIN_PASSWORD=admin_secret
